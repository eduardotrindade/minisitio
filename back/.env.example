# ============================================================
#   MINISITIO — Configuração do Backend
#   Copie este arquivo para .env e preencha os valores reais
#   NUNCA commite o arquivo .env no git!
# ============================================================

# ── Servidor ────────────────────────────────────────────────
PORT=3032
NODE_ENV=development
# Para produção use: NODE_ENV=production

# ── Banco de Dados MySQL ─────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=root
DB_PASSWORD=SUA_SENHA_AQUI
DB_NAME=minisitio_local
# Para produção:
# DB_HOST=IP_DO_SERVIDOR_MYSQL
# DB_PORT=3306
# DB_NAME=miniv2_minisitio_prod

# ── CORS (Origens permitidas, separadas por vírgula) ─────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000
# Para produção: ALLOWED_ORIGINS=https://seudominio.com.br,https://www.seudominio.com.br

# ── JWT (Autenticação) ───────────────────────────────────────
JWT_SECRET=gere_uma_chave_forte_aqui_com_64_caracteres_minimo
JWT_EXPIRE=24h
# Para gerar uma boa chave: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# ── Frontend URL ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
# Para produção: FRONTEND_URL=https://seudominio.com.br

# ── API Config ───────────────────────────────────────────────
API_URL=http://localhost:3032/api
API_SECRET=GERE_UMA_CHAVE_SECRETA_FORTE
SECRET_KEY_WEBHOOK=GERE_OUTRA_CHAVE_FORTE_AQUI

# ── Mercado Pago — Sandbox (Testes) ──────────────────────────
MP_PUBLIC_KEY_SANDBOX=TEST-xxxxx-yyyyy-zzzzz
MP_ACCESS_TOKEN_SANDBOX=TEST-xxxxxxxxxx-xxxxxxxx

# ── Mercado Pago — Produção ───────────────────────────────────
MP_PUBLIC_KEY_PROD=APP_USR-xxxxxxxxxx
MP_ACCESS_TOKEN_PROD=APP_USR-xxxxxxxxxxxx
MP_CLIENT_ID=XXXXXXXXXX
MP_CLIENT_SECRET=XXXXXXXXXXXXXXXXXX

# ── Segurança ────────────────────────────────────────────────
USE_HELMET=false
# Para produção: USE_HELMET=true

# ── Logs ─────────────────────────────────────────────────────
LOG_LEVEL=debug
# Para produção: LOG_LEVEL=error
